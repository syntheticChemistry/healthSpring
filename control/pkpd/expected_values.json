{
  "track": "pkpd",
  "description": "Pharmacokinetics / Pharmacodynamics — analytical baselines from peer-reviewed literature",
  "spring": "healthSpring",
  "created": "2026-05-13",
  "scripts": {
    "exp001_hill_dose_response": {
      "paper": "Hill AV (1910) The possible effects of the aggregation of the molecules of haemoglobin on its dissociation curves. J Physiol 40(suppl):iv–vii",
      "doi": "10.1113/jphysiol.1910.sp001014",
      "model": "Hill dose-response: E = Emax * C^n / (IC50^n + C^n)",
      "key_parameters": {
        "ic50_ng_ml": 44.5,
        "hill_n": 1.8,
        "emax": 1.0
      },
      "analytical_checks": [
        "E(IC50) = 0.5 (definition of IC50)",
        "E(0) = 0 (no effect at zero dose)",
        "E(∞) → Emax (saturation)",
        "Monotonically increasing for n > 0",
        "Steeper sigmoid for higher n"
      ]
    },
    "exp002_one_compartment_pk": {
      "paper": "Rowland M, Tozer TN. Clinical Pharmacokinetics and Pharmacodynamics, 4th ed. Ch. 3-4.",
      "isbn": "978-0781750097",
      "model": "One-compartment: C(t) = (F*D*ka)/(Vd*(ka-ke)) * (exp(-ke*t) - exp(-ka*t))",
      "key_parameters": {
        "cl_L_hr": 10.0,
        "vd_L": 80.0,
        "ka_hr": 1.5,
        "bioavailability": 0.85
      },
      "analytical_checks": [
        "AUC = F*Dose / CL",
        "C(0) = 0 for oral",
        "C(0) = Dose/Vd for IV",
        "t½ = ln(2) * Vd / CL"
      ]
    },
    "exp003_two_compartment_pk": {
      "paper": "Rowland M, Tozer TN. Clinical Pharmacokinetics and Pharmacodynamics, 4th ed. Ch. 19.",
      "isbn": "978-0781750097",
      "model": "C(t) = A*exp(-α*t) + B*exp(-β*t)",
      "key_parameters": {
        "dose_mg": 240.0,
        "v1_L": 15.0,
        "k10_hr": 0.35,
        "k12_hr": 0.6,
        "k21_hr": 0.15
      },
      "analytical_checks": [
        "α + β = k10 + k12 + k21",
        "α * β = k10 * k21",
        "A + B = C0 = Dose/V1",
        "AUC = Dose / (V1 * k10)",
        "Terminal slope = -β"
      ]
    },
    "exp004_mab_pk_transfer": {
      "papers": [
        {"author": "Gonzales AJ, Fleck TJ et al.", "year": 2021, "journal": "Vet Dermatol", "doi": "10.1111/vde.12187", "note": "lokivetmab canine PK (nS-603)"},
        {"author": "Kabashima K et al.", "year": 2020, "journal": "NEJM", "doi": "10.1056/NEJMoa1917006", "note": "nemolizumab Phase III"},
        {"author": "Mahmood I, Balian JD", "year": 1996, "journal": "J Pharm Sci", "doi": "10.1007/BF02353864", "note": "allometric scaling"}
      ],
      "model": "Allometric: Param_human = Param_animal * (BW_h/BW_a)^b",
      "key_parameters": {
        "allometric_cl": 0.75,
        "allometric_vd": 1.0,
        "allometric_half_life": 0.25
      }
    },
    "exp005_population_pk": {
      "papers": [
        {"author": "Mould DR, Upton RN", "year": 2013, "journal": "CPT:PSP", "doi": "10.1038/psp.2013.14", "note": "Basic concepts in population modeling"},
        {"author": "Rowland M, Tozer TN", "note": "Ch. 18 population PK"}
      ],
      "model": "Lognormal IIV on CL/Vd/ka, one-compartment oral Bateman",
      "key_parameters": {
        "cl_typical_L_hr": 10.0,
        "cl_cv": 0.30,
        "vd_typical_L": 80.0,
        "ka_typical_hr": 1.5,
        "f_bioavail": 0.79,
        "n_patients": 1000,
        "seed": 42
      }
    },
    "exp006_pbpk_compartments": {
      "paper": "Gabrielsson J, Weiner D. Pharmacokinetic and Pharmacodynamic Data Analysis, 5th ed.",
      "isbn": "978-9197651004",
      "model": "5-tissue PBPK, Euler integration, IV bolus"
    },
    "exp077_michaelis_menten_pk": {
      "papers": [
        {"author": "Rowland M, Tozer TN", "note": "Ch. 20 capacity-limited elimination"},
        {"author": "Ludden TM et al.", "year": 1977, "journal": "Clin Pharmacol Ther", "doi": "10.1016/0009-9236(77)90012-7", "note": "phenytoin nonlinear PK"}
      ],
      "model": "Michaelis-Menten: dC/dt = -Vmax*C/(Km + C)",
      "key_parameters": {
        "vmax_mg_day": 500.0,
        "km_mg_L": 5.0,
        "vd_L": 50.0
      }
    }
  }
}
